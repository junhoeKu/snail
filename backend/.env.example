# 운영 배포 시 필수 설정 — 시크릿은 절대 커밋하지 않는다
ENV=prod
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET=<openssl rand -hex 32 로 생성>
CORS_ORIGINS=https://junhoeku.github.io
GOOGLE_CLIENT_ID=<Google Cloud OAuth 클라이언트 ID (선택)>
ADMIN_TOKEN=<openssl rand -hex 32 로 생성 — 어드민/원격설정 API 보호 (비면 어드민 비활성)>
MAX_SNAILS=3
